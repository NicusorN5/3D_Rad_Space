<platform:DialogWindow 
	x:Class="_3DRadSpace_VSExtension.ObjectWizardDialog"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:platform="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
	Title="Create new Object"
	Width="500" Height="389"
	WindowStartupLocation="CenterOwner">

    <Grid Margin="12,0,12,12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configure your object:" FontSize="14" Margin="0,12,0,12"/>

        <StackPanel Grid.Row="1">
            <Label Content="Class Name:" />
            <TextBox x:Name="ClassNameBox" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,8,0,0">
            <Label Content="Base Class:" />
            <ComboBox x:Name="BaseClassComboBox">
                <ComboBoxItem Content="IObject" IsSelected="True"/>
                <ComboBoxItem Content="IObject2D"/>
                <ComboBoxItem Content="IObject3D"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Click="ConfirmObj" Width="75" Height="25" IsDefault="True" Margin="0,0,8,0"/>
            <Button Content="Cancel" IsCancel="True" Width="75" Height="25"/>
        </StackPanel>

    </Grid>

</platform:DialogWindow>